# Variables de entorno del backend
# Copiá este archivo como .env y completá con tus valores

# Puerto del servidor
PORT=3000

# Supabase - pedile a Miguel las credenciales
SUPABASE_URL=
SUPABASE_KEY=

# JWT - pedile a Miguel la clave o generá una nueva (mínimo 32 caracteres)
JWT_SECRET=

# Email para forgot password - pedile a Miguel los datos
EMAIL_USER=
EMAIL_PASS=